{
  "name": "reels-factory-desktop",
  "version": "0.1.13",
  "description": "AI Reels Factory — настольное приложение (ТЗ → видео с озвучкой), полностью локальный рендер",
  "author": "MarkVision",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "test:render": "node src/test-render.js",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "kz.markvision.reelsfactory",
    "productName": "AI Reels Factory",
    "files": ["main.js", "preload.cjs", "src/**", "renderer/**", "assets/**"],
    "asarUnpack": ["node_modules/ffmpeg-static/**"],
    "mac": { "target": ["dmg", "zip"], "category": "public.app-category.productivity" },
    "win": { "target": "nsis" },
    "publish": { "provider": "github", "owner": "MarkVision2", "repo": "reels-factory-releases" }
  }
}
